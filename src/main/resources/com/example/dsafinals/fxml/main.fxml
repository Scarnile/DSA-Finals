<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="500.0" minWidth="800.0" prefHeight="500.0" prefWidth="1000.0" stylesheets="@../stylesheets/application.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dsafinals.controllers.MainController">
    <center>
        <BorderPane style="-fx-background-color: #0a0a0a;" BorderPane.alignment="CENTER">
            <top>
                <BorderPane minHeight="-Infinity" prefWidth="760.0" BorderPane.alignment="CENTER">
                    <top>
                        <HBox alignment="BASELINE_CENTER" maxWidth="1.7976931348623157E308" prefHeight="55.0" prefWidth="750.0" style="-fx-border-width: 0 0 1px 0;" styleClass="border" BorderPane.alignment="CENTER">
                            <children>
                        <Button fx:id="undoButton" mnemonicParsing="false" style="-fx-icon-color: white;" styleClass="transparent-button" stylesheets="@../stylesheets/buttons.css" textFill="WHITE">
                           <HBox.margin>
                              <Insets left="20.0" />
                           </HBox.margin>
                        </Button>
                        <Button fx:id="redoButton" mnemonicParsing="false" styleClass="transparent-button" stylesheets="@../stylesheets/buttons.css" textFill="WHITE" />
                                <Region prefHeight="20.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                <Button fx:id="newEntryButton" minWidth="-Infinity" mnemonicParsing="false" styleClass="primary-button" stylesheets="@../stylesheets/buttons.css" text="New Entry">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                    <padding>
                                        <Insets bottom="10.0" left="17.0" right="17.0" top="10.0" />
                                    </padding>
                                    <HBox.margin>
                                        <Insets right="20.0" />
                                    </HBox.margin>
                                </Button>
                            </children>
                            <BorderPane.margin>
                                <Insets top="15.0" />
                            </BorderPane.margin>
                        </HBox>
                    </top>
                </BorderPane>
            </top>
         <center>
            <StackPane fx:id="contentArea" alignment="TOP_RIGHT" maxWidth="1.7976931348623157E308" prefHeight="150.0" BorderPane.alignment="CENTER" />
         </center>
        </BorderPane>
    </center>
    <left>
        <VBox fx:id="sidebar" maxWidth="260.0" minWidth="220.0" prefHeight="620.0" prefWidth="250.0" spacing="8.0" style="-fx-background-color: #171717; -fx-border-width: 0 1px 0 0;" styleClass="border" stylesheets="@../stylesheets/buttons.css" BorderPane.alignment="CENTER">
            <children>
                <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Digital Journal">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Text>
                <Button fx:id="dashboardButton" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" stylesheets="@../stylesheets/buttons.css" text="Dashboard" textFill="WHITE">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <styleClass>
                        <String fx:value="selected-button" />
                        <String fx:value="sidebar-button" />
                    </styleClass>
                </Button>
                <Button fx:id="journalButton" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Journal" textFill="WHITE">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <Button fx:id="albumsButton" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Albums" textFill="WHITE">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <Button fx:id="photosButton" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Photos" textFill="WHITE">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
                <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                <Button fx:id="settingsButton" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-button" text="Settings" textFill="WHITE">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="15.0" top="22.0" />
            </padding>
        </VBox>
    </left>
</BorderPane>
